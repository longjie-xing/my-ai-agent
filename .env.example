# ============================================
# Agnes AI API 配置（OpenAI 兼容格式）
# ============================================
# 1. 登录 https://platform.agnes-ai.com/settings/apiKeys 创建 API Key
# 2. 将下方的 YOUR_API_KEY 替换为你的 Key
# 3. 保存后即可使用

# API Key（从 platform.agnes-ai.com 获取）
AGNES_API_KEY=YOUR_API_KEY

# API Base URL
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# Model ID（推荐使用 agnes-2.0-flash）
AGNES_MODEL_ID=agnes-2.0-flash
